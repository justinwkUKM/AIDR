{
  "manifest_version": 3,
  "name": "AIDR - AI Detection and Response",
  "version": "0.1.0",
  "description": "On-device AI Detection and Response security layer for AI chat platforms.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://*.chatgpt.com/*",
    "https://*.openai.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self'; frame-ancestors 'none'"
  },
  "action": {
    "default_title": "AIDR Dashboard",
    "default_popup": "dashboard/dashboard.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.chatgpt.com/*",
        "https://*.openai.com/*"
      ],
      "js": [
        "aidr/aidr-config.js",
        "aidr/aidr-policy.js",
        "aidr/aidr-rules.js",
        "aidr/aidr-patterns.js",
        "aidr/aidr-detector.js",
        "aidr/aidr-scorer.js",
        "aidr/aidr-logger.js",
        "aidr/aidr-responder.js",
        "aidr/aidr-core.js",
        "content.js"
      ],
      "css": ["styles.css", "aidr/aidr-styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "aidr/page-transport-guard.js",
        "icons/icon16.png",
        "icons/icon32.png",
        "icons/icon48.png",
        "icons/icon128.png"
      ],
      "matches": [
        "https://*.chatgpt.com/*",
        "https://*.openai.com/*"
      ]
    }
  ]
}
